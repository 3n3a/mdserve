<h1>Table of Contents</h1>
{{- range .Groups}}
<h2>{{if .Folder}}{{.Folder}}{{else}}Files{{end}}</h2>
<table role="grid"><thead><tr><th>File</th><th>Title</th></tr></thead><tbody>
{{- range .Entries}}
<tr><td><a href="{{.URLPath}}">{{.File}}</a></td><td>{{.Title}}</td></tr>
{{- end}}
</tbody></table>
{{- end}}
